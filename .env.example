# Direct local-development database connection. Docker Compose normally uses
# DB_*_FILE secrets instead, as shown in docker-compose.yaml.
DATABASE_URL=postgres://termincount:termincount@127.0.0.1:5432/termincount
DATABASE_URL_FILE=
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=termincount
DB_USER=termincount
DB_PASSWORD=termincount
POSTGRES_PORT=5432
TERMINCOUNT_PORT=8080
TERMINCOUNT_RETENTION_DAYS=7
TERMINCOUNT_CLEANUP_INTERVAL_MINUTES=60
TERMINCOUNT_DB_POOL_SIZE=10

# Public URL used to generate share links and validate proxied requests.
# Local example: http://localhost:8080
# Production example: https://termincount.diegosr.es
ORIGIN=http://localhost:8080
